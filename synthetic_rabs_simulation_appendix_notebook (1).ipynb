# Generate the synthetic dataset, summary, notebook, and README

import json
from pathlib import Path
import numpy as np
import pandas as pd

outdir = Path("/mnt/data")
outdir.mkdir(parents=True, exist_ok=True)

rng = np.random.default_rng(42)

# ----------------------------
# Synthetic dataset generation
# ----------------------------
n_events = 180
n_sensors = 6
n_timesteps = 60
sensor_positions = np.arange(n_sensors)

event_types = ["GloveBreach", "MechanicalFriction", "HVACDrift"]
source_locations = [1, 2, 3, 4]

records = []
summary_rows = []

def glove_breach_pattern(t):
    return 18 * np.exp(-0.10 * t)

def mechanical_pattern(t):
    return 6 + 4*np.sin(2*np.pi*t/8) + 2*np.sin(2*np.pi*t/4)

def hvac_drift_pattern(t):
    return 0.20 * t

for event_id in range(1, n_events + 1):
    event_type = event_types[(event_id - 1) % len(event_types)]
    source = int(rng.choice(source_locations))
    baseline = float(rng.uniform(1.0, 3.0))
    event_start = int(rng.integers(8, 16))
    airflow_decay = float(rng.uniform(0.7, 1.3))
    source_strength = float(rng.uniform(0.9, 1.2))

    for sensor in sensor_positions:
        distance = abs(sensor - source)
        spatial_weight = np.exp(-(distance / airflow_decay))

        for t in range(n_timesteps):
            lam = baseline

            if t >= event_start:
                local_t = t - event_start
                if event_type == "GloveBreach":
                    lam += source_strength * spatial_weight * glove_breach_pattern(local_t)
                elif event_type == "MechanicalFriction":
                    lam += source_strength * spatial_weight * mechanical_pattern(local_t)
                elif event_type == "HVACDrift":
                    lam += source_strength * (0.6 + 0.4 * spatial_weight) * hvac_drift_pattern(local_t)

            lam = max(lam, 0.05)
            count = int(rng.poisson(lam))
            ft_transform = float(np.sqrt(count) + np.sqrt(count + 1))

            records.append(
                {
                    "event_id": event_id,
                    "event_type": event_type,
                    "source_location": source,
                    "sensor_id": sensor,
                    "sensor_position": float(sensor),
                    "time_step": t,
                    "baseline_lambda": baseline,
                    "event_start": event_start,
                    "airflow_decay": airflow_decay,
                    "source_strength": source_strength,
                    "distance_from_source": distance,
                    "spatial_weight": spatial_weight,
                    "particle_count": count,
                    "freeman_tukey": ft_transform,
                }
            )

    summary_rows.append(
        {
            "event_id": event_id,
            "event_type": event_type,
            "source_location": source,
            "baseline_lambda": baseline,
            "event_start": event_start,
            "airflow_decay": airflow_decay,
            "source_strength": source_strength,
        }
    )

df = pd.DataFrame(records)
summary_df = pd.DataFrame(summary_rows)

csv_path = outdir / "synthetic_rabs_particle_dataset.csv"
summary_path = outdir / "synthetic_rabs_event_summary.csv"
df.to_csv(csv_path, index=False)
summary_df.to_csv(summary_path, index=False)

# ----------------------------
# Build a Jupyter notebook
# ----------------------------
notebook_cells = []

def md_cell(text):
    return {
        "cell_type": "markdown",
        "metadata": {},
        "source": text.splitlines(keepends=True),
    }

def code_cell(code):
    return {
        "cell_type": "code",
        "execution_count": None,
        "metadata": {},
        "outputs": [],
        "source": code.splitlines(keepends=True),
    }

notebook_cells.append(md_cell(
"""# Appendix A. Synthetic Dataset and Reproducible Simulation Workflow

This notebook generates a synthetic environmental monitoring dataset for an aseptic Restricted Access Barrier System (RABS).  

## Objectives
1. Simulate particle-count time series from multiple sensors.
2. Encode three contamination mechanisms:
   - Glove breach
   - Mechanical friction
   - HVAC drift
3. Preserve metadata needed for classification and localization.

## Output files
- synthetic_rabs_particle_dataset.csv
- synthetic_rabs_event_summary.csv
"""
))

notebook_cells.append(code_cell(
"""import numpy as np
import pandas as pd

# Load dataset
df = pd.read_csv("synthetic_rabs_particle_dataset.csv")
df.head()
"""
))

notebook = {
    "cells": notebook_cells,
    "metadata": {
        "kernelspec": {
            "display_name": "Python 3",
            "language": "python",
            "name": "python3",
        },
        "language_info": {
            "name": "python",
            "version": "3.11",
        },
    },
    "nbformat": 4,
    "nbformat_minor": 5,
}

ipynb_path = outdir / "synthetic_rabs_simulation_appendix_notebook.ipynb"
with open(ipynb_path, "w", encoding="utf-8") as f:
    json.dump(notebook, f, indent=2)

# README
readme_path = outdir / "synthetic_rabs_appendix_readme.txt"
readme_path.write_text(
    "Synthetic RABS dataset package.\n"
    "Includes dataset, summary, and notebook for reproducible simulation.\n",
    encoding="utf-8"
)

csv_path, summary_path, ipynb_path, readme_path


